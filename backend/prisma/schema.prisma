generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CarType {
  economy
  premium
  luxury
}

enum ItemType {
  car
  package
}

enum BookingStatus {
  pending
  confirmed
  cancelled
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  cart      CartItem[]
  bookings  Booking[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

model CartItem {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId   String
  itemType ItemType
  price    Float

  @@map("cart_items")
}

model Car {
  id           String    @id @default(uuid())
  name         String
  type         CarType
  price        Float
  description  String?
  availability Boolean   @default(true)
  image        String?
  bookings     Booking[]

  @@map("cars")
}

model Package {
  id           String   @id @default(uuid())
  name         String
  price        Float
  destinations String[]
  couponCode   String?
  image        String
  availability Boolean  @default(true)

  @@map("packages")
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId      String
  car        Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("bookings")
}
